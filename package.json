{
  "name": "thunder-kitty-site",
  "version": "1.0.0",
  "description": "Marketing site for Thunder Kitty — local-first meeting transcription for macOS",
  "scripts": {
    "build:css": "tailwindcss -i ./src/css/main.css -o ./public/css/main.css --minify",
    "watch:css": "tailwindcss -i ./src/css/main.css -o ./public/css/main.css --watch",
    "build:11ty": "eleventy",
    "watch:11ty": "eleventy --serve",
    "dev": "concurrently --kill-others-on-fail --names \"CSS,11TY\" --prefix-colors \"magenta,cyan\" \"npm:watch:css\" \"npm:watch:11ty\"",
    "build": "npm run build:css && npm run build:11ty",
    "format": "prettier --write ."
  },
  "devDependencies": {
    "@11ty/eleventy": "^3.0.0",
    "autoprefixer": "^10.5.0",
    "concurrently": "^9.2.1",
    "daisyui": "^4.12.24",
    "postcss": "^8.5.10",
    "prettier": "^3.8.1",
    "tailwindcss": "^3.4.19"
  }
}
